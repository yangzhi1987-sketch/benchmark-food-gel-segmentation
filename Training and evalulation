class PatchDataset(Dataset):
    def __init__(self, pairs: List[Tuple[str,str]], patch: int, n_patches_per_image: int,
                 aug: Optional[A.Compose] = None, oversample_fg: float = 0.7):
        self.pairs = pairs
        self.patch = patch
        self.n_patches = n_patches_per_image
        self.aug = aug
        self.oversample_fg = oversample_fg

    def __len__(self):
        return len(self.pairs) * self.n_patches

    def __getitem__(self, idx):
        im_path, mk_path = self.pairs[idx // self.n_patches]

        img = norm01(read_gray(im_path))
        # protein=1 (white), void=0
        msk = (read_gray(mk_path) > 127).astype(np.uint8)

        H, W = img.shape
        p = self.patch

        if H < p or W < p:
            pad_h = max(0, p - H)
            pad_w = max(0, p - W)
            img = np.pad(img, ((0, pad_h), (0, pad_w)), mode="reflect")
            msk = np.pad(msk, ((0, pad_h), (0, pad_w)), mode="constant", constant_values=0)
            H, W = img.shape

        for _ in range(10):
            y = random.randint(0, H - p)
            x = random.randint(0, W - p)
            pm = msk[y:y+p, x:x+p]
            if random.random() > self.oversample_fg or pm.mean() > 0.02:
                break

        imgp = img[y:y+p, x:x+p]
        mskp = msk[y:y+p, x:x+p]

        if self.aug is not None:
            out = self.aug(image=(imgp*255).astype(np.uint8), mask=mskp.astype(np.uint8))
            imgp = out["image"].astype(np.float32) / 255.0
            mskp = out["mask"].astype(np.float32)

        img_t = torch.from_numpy(imgp).unsqueeze(0).float()
        msk_t = torch.from_numpy(mskp).unsqueeze(0).float()
        return img_t, msk_t


class FullImageDataset(Dataset):
    def __init__(self, pairs: List[Tuple[str,str]]):
        self.pairs = pairs
    def __len__(self):
        return len(self.pairs)
    def __getitem__(self, idx):
        ip, mp = self.pairs[idx]
        img = norm01(read_gray(ip))
        gt = (read_gray(mp) > 127).astype(np.uint8)  # protein=1
        return ip, img, gt


# =========================
# STRUCTURAL METRICS
# =========================
def fractal_dimension_boxcount(mask: np.ndarray, scales: Tuple[int, ...]) -> float:
    """
    Box-count FD using ONLY provided scales (e.g., 8,16,32,64,128).
    Count N(s) = number of boxes with ANY foreground.
    Fit: log(N) vs log(1/s) slope -> FD
    """
    Z = (mask > 0).astype(np.uint8)
    H, W = Z.shape
    max_s = min(H, W)
    ss = [s for s in scales if 2 <= s <= max_s]
    ss = sorted(list(set(ss)))
    if len(ss) < 2:
        return float("nan")

    Ns = []
    Ss = []
    for s in ss:
        Hc = (H // s) * s
        Wc = (W // s) * s
        if Hc == 0 or Wc == 0:
            continue
        Zc = Z[:Hc, :Wc]
        # reshape into blocks (Hc/s, s, Wc/s, s)
        blocks = Zc.reshape(Hc//s, s, Wc//s, s)
        block_sum = blocks.sum(axis=(1,3))
        n = int(np.count_nonzero(block_sum > 0))
        if n > 0:
            Ns.append(n)
            Ss.append(s)

    if len(Ns) < 2:
        return float("nan")

    x = np.log(1.0 / np.array(Ss, dtype=np.float64))
    y = np.log(np.array(Ns, dtype=np.float64))
    a, _b = np.polyfit(x, y, 1)
    return float(a)

def lacunarity_gliding_box(mask: np.ndarray, box: int = 16, stride: Optional[int] = None) -> float:
    Z = (mask > 0).astype(np.uint8)
    h, w = Z.shape
    if h < box or w < box:
        return float("nan")
    if stride is None:
        stride = max(1, box // 4)

    ii = cv2.integral(Z)
    sums = []
    for y in range(0, h - box + 1, stride):
        y2 = y + box
        for x in range(0, w - box + 1, stride):
            x2 = x + box
            s = ii[y2, x2] - ii[y, x2] - ii[y2, x] + ii[y, x]
            sums.append(s)

    sums = np.array(sums, dtype=np.float32)
    if sums.size < 10:
        return float("nan")
    mu = float(sums.mean())
    if mu <= 1e-6:
        return float("nan")
    var = float(sums.var())
    return float(var / (mu * mu) + 1.0)

def betti_numbers_2d(mask: np.ndarray, connectivity: int = 2) -> Tuple[float, float]:
    fg = (mask > 0).astype(np.uint8)
    lab_fg = label(fg, connectivity=connectivity)
    b0 = int(lab_fg.max())

    bg = (1 - fg).astype(np.uint8)
    lab_bg = label(bg, connectivity=connectivity)
    n_bg = int(lab_bg.max())
    if n_bg == 0:
        return float(b0), 0.0

    border_labels = set(np.unique(lab_bg[0, :]).tolist()
                        + np.unique(lab_bg[-1, :]).tolist()
                        + np.unique(lab_bg[:, 0]).tolist()
                        + np.unique(lab_bg[:, -1]).tolist())
    border_labels.discard(0)
    holes = max(0, n_bg - len(border_labels))
    return float(b0), float(holes)

def protein_aggregation_area_mean(mask: np.ndarray, min_area: int, cleanup_remove_small: bool) -> float:
    """
    Protein aggregation area = mean area of connected protein components (protein=1).
    We optionally remove small objects first to avoid tiny specks.
    """
    fg = (mask > 0)
    if cleanup_remove_small:
        fg = remove_small_objects(fg, min_size=min_area)

    lab = label(fg.astype(np.uint8), connectivity=2)
    props = regionprops(lab)
    areas = [p.area for p in props if p.area >= min_area]
    if len(areas) == 0:
        return float("nan")
    return float(np.mean(np.array(areas, dtype=np.float32)))

def protein_area_fraction(mask: np.ndarray) -> float:
    fg = (mask > 0).astype(np.uint8)
    return float(fg.mean())

def compute_descriptors(cfg: CFG, mask: np.ndarray) -> Dict[str, float]:
    fg = (mask > 0).astype(np.uint8)
    out = {}
    out["protein_area_frac"] = protein_area_fraction(fg)
    out["agg_area_mean"] = protein_aggregation_area_mean(
        fg, min_area=cfg.min_agg_area_px, cleanup_remove_small=cfg.agg_cleanup_remove_small
    )
    out["fd"] = fractal_dimension_boxcount(fg, cfg.fd_scales)
    out["lac"] = lacunarity_gliding_box(fg, box=cfg.lac_box, stride=cfg.lac_stride)
    out["euler"] = float(euler_number(fg, connectivity=2))
    b0, b1 = betti_numbers_2d(fg, connectivity=2)
    out["betti0"] = b0
    out["betti1"] = b1
    return out


