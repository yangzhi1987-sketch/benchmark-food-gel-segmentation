def build_model(spec: Dict) -> nn.Module:
    arch = spec["arch"]
    encoder = spec["encoder"]
    attn = spec.get("decoder_attention_type", None)

    kwargs = dict(
        encoder_name=encoder,
        encoder_weights="imagenet",
        in_channels=1,
        classes=1
    )
    if arch in ["Unet", "UnetPlusPlus"] and attn is not None:
        kwargs["decoder_attention_type"] = attn

    if not hasattr(smp, arch):
        raise ValueError(f"SMP arch not available in your version: {arch} (model={spec['name']})")

    return getattr(smp, arch)(**kwargs)

