def scatter_plot_with_fit(cfg: CFG, gt: np.ndarray, pr: np.ndarray, title: str, save_path: PathLike):
    gt = gt.astype(np.float64); pr = pr.astype(np.float64)
    ok = np.isfinite(gt) & np.isfinite(pr)
    if ok.sum() < 3:
        return None

    x = gt[ok]
    y = pr[ok]

    a, b = np.polyfit(x, y, 1)  # y = a x + b
    y_fit = a * x + b

    r2_pred = float(r2_score(x, y))          # identity fidelity GT vs Pred
    r2_fit  = float(r2_score(y, y_fit))      # fit quality
    r = float(np.corrcoef(x, y)[0, 1])
    r2_pear = float(r * r)

    mn = float(min(x.min(), y.min()))
    mx = float(max(x.max(), y.max()))
    xx = np.linspace(mn, mx, 200)
    yy = a * xx + b

    plt.figure(figsize=(6,5))
    plt.scatter(x, y, s=20)
    plt.plot([mn, mx], [mn, mx], label="y=x")
    plt.plot(xx, yy, label=f"y={a:.3f}x+{b:.3f}")
    plt.title(f"{title}\nR²_pred={r2_pred:.3f} | R²_fit={r2_fit:.3f} | r²={r2_pear:.3f}")
    plt.xlabel("GT"); plt.ylabel("Pred")
    plt.legend()
    plt.tight_layout()
    plt.savefig(str(save_path), dpi=cfg.dpi)
    _show_and_close(cfg)

    return {"a": float(a), "b": float(b), "r2_pred": r2_pred, "r2_fit": r2_fit, "r2_pear": r2_pear, "n": int(ok.sum())}

def bland_altman_plot(cfg: CFG, gt: np.ndarray, pr: np.ndarray, title: str, save_path: PathLike):
    gt = gt.astype(np.float64); pr = pr.astype(np.float64)
    ok = np.isfinite(gt) & np.isfinite(pr)
    if ok.sum() < 3:
        return None

    m = (gt[ok] + pr[ok]) / 2.0
    d = (pr[ok] - gt[ok])

    bias = float(np.mean(d))
    sd = float(np.std(d, ddof=1)) if d.size > 1 else 0.0
    loa1 = bias - 1.96 * sd
    loa2 = bias + 1.96 * sd

    plt.figure(figsize=(6,5))
    plt.scatter(m, d, s=20)
    plt.axhline(bias, linestyle="--", label="bias")
    plt.axhline(loa1, linestyle="--", label="LoA")
    plt.axhline(loa2, linestyle="--")
    plt.title(f"{title}\nBias={bias:.3g}, LoA=[{loa1:.3g}, {loa2:.3g}]")
    plt.xlabel("Mean(GT, Pred)"); plt.ylabel("Pred - GT")
    plt.legend()
    plt.tight_layout()
    plt.savefig(str(save_path), dpi=cfg.dpi)
    _show_and_close(cfg)

    return {"bias": bias, "sd": sd, "loa_low": loa1, "loa_high": loa2, "n": int(ok.sum())}


