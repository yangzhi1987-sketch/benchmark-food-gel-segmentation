def plot_model_summary(cfg: CFG, leaderboard: pd.DataFrame, out_dir: Path):
    ensure_dir(out_dir)

    # Sort by Dice
    ld = leaderboard.copy()
    ld = ld.sort_values("test_dice_mean", ascending=False)

    # Dice/IoU bar
    plt.figure(figsize=(10, 5))
    plt.bar(ld["name"], ld["test_dice_mean"], label="Dice")
    plt.bar(ld["name"], ld["test_iou_mean"], label="IoU", alpha=0.7)
    plt.xticks(rotation=45, ha="right")
    plt.ylabel("Score")
    plt.title("Model summary: Dice & IoU (Test)")
    plt.legend()
    plt.tight_layout()
    plt.savefig(out_dir / "summary_dice_iou.png", dpi=cfg.dpi)
    _show_and_close(cfg)

    # Descriptor R²_pred bar plots
    metric_list = ["protein_area_frac", "agg_area_mean", "fd", "lac", "euler", "betti0", "betti1"]
    for m in metric_list:
        col = f"{m}_r2_pred"
        if col not in ld.columns:
            continue
        plt.figure(figsize=(10, 4))
        plt.bar(ld["name"], ld[col])
        plt.xticks(rotation=45, ha="right")
        plt.ylabel("R²_pred (GT vs Pred)")
        plt.title(f"Model summary: {m} (R²_pred)")
        plt.tight_layout()
        plt.savefig(out_dir / f"summary_r2pred_{m}.png", dpi=cfg.dpi)
        _show_and_close(cfg)


