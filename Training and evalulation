    ts = datetime.now().strftime("%Y%m%d_%H%M%S")
    run_name = f"{spec['name']}__{ts}"
    out_dir = Path(cfg.output_root) / run_name

    ensure_dir(out_dir)
    ensure_dir(out_dir / "checkpoints")
    ensure_dir(out_dir / "figs_train")
    ensure_dir(out_dir / "figs_test")
    ensure_dir(out_dir / "pred_masks")
    ensure_dir(out_dir / "panel_all")          # ALL three-panels

    with open(out_dir / "run_config.json", "w") as f:
        json.dump({"cfg": asdict(cfg), "model_spec": spec}, f, indent=2)

    ds_tr = PatchDataset(train_pairs, patch=cfg.patch, n_patches_per_image=cfg.n_patches_per_image, aug=aug_train)
    ds_va = PatchDataset(val_pairs, patch=cfg.patch, n_patches_per_image=max(2, cfg.n_patches_per_image // 2), aug=aug_val)
    dl_tr = DataLoader(ds_tr, batch_size=cfg.batch_size, shuffle=True, num_workers=cfg.num_workers)
    dl_va = DataLoader(ds_va, batch_size=cfg.batch_size, shuffle=False, num_workers=cfg.num_workers)

    model = build_model(spec).to(device)
    opt = torch.optim.AdamW(model.parameters(), lr=cfg.lr, weight_decay=cfg.weight_decay)
    bce = nn.BCEWithLogitsLoss()

    best_va_dice = -1.0
    best_epoch = -1

    history_rows = []

    for epoch in range(1, cfg.epochs + 1):
        model.train()
        tr_losses = []
        for x, y in tqdm(dl_tr, desc=f"[{spec['name']}] epoch {epoch}/{cfg.epochs} train"):
            x, y = x.to(device), y.to(device)
            opt.zero_grad(set_to_none=True)
            logits = model(x)
            loss = bce(logits, y) + dice_loss_with_logits(logits, y)
            loss.backward()
            opt.step()
            tr_losses.append(loss.item())

        model.eval()
        va_losses = []
        va_dices = []
        va_ious = []
        with torch.no_grad():
            for x, y in tqdm(dl_va, desc=f"[{spec['name']}] epoch {epoch}/{cfg.epochs} val"):
                x, y = x.to(device), y.to(device)
                logits = model(x)
                loss = bce(logits, y) + dice_loss_with_logits(logits, y)
                va_losses.append(loss.item())

                # quick validation dice/iou on patches
                probs = torch.sigmoid(logits)
                pred = (probs > cfg.threshold).float()
                inter = (pred * y).sum(dim=(2,3))
                den = (pred.sum(dim=(2,3)) + y.sum(dim=(2,3)) + 1e-6)
                dice = (2*inter / den).mean().item()
                union = (pred + y - pred*y).sum(dim=(2,3)) + 1e-6
                iou = (inter / union).mean().item()
                va_dices.append(dice)
                va_ious.append(iou)

        tr_loss = float(np.mean(tr_losses))
        va_loss = float(np.mean(va_losses))
        va_dice = float(np.mean(va_dices))
        va_iou  = float(np.mean(va_ious))

        history_rows.append({
            "epoch": epoch,
            "train_loss": tr_loss,
            "val_loss": va_loss,
            "val_dice": va_dice,
            "val_iou": va_iou,
            "lr": float(opt.param_groups[0]["lr"]),
        })

        hist_df = pd.DataFrame(history_rows)
        hist_df.to_csv(out_dir / "figs_train" / "training_history.csv", index=False)  # ✅ save CSV
        plot_loss_curves(cfg, hist_df, out_dir / "figs_train" / "loss_curve.png", title=spec["name"])

        print(f"[{spec['name']}] Epoch {epoch}: tr_loss={tr_loss:.4f} va_loss={va_loss:.4f} va_dice={va_dice:.4f} va_iou={va_iou:.4f}")

        if va_dice > best_va_dice:
            best_va_dice = va_dice
            best_epoch = epoch
            torch.save({"model": model.state_dict(), "epoch": epoch, "best_va_dice": best_va_dice},
                       out_dir / "checkpoints" / "best.pt")

    # Load best
    ckpt = torch.load(out_dir / "checkpoints" / "best.pt", map_location="cpu")
    model.load_state_dict(ckpt["model"], strict=True)
    model.to(device)
    model.eval()

    # TEST full images
    ds_test = FullImageDataset(test_pairs)

    metric_list = ["protein_area_frac", "agg_area_mean", "fd", "lac", "euler", "betti0", "betti1"]
    rows = []

    for i in tqdm(range(len(ds_test)), desc=f"[{spec['name']}] test full"):
        path, img, gt = ds_test[i]
        prob = predict_full_prob(model, img, device, patch=cfg.patch, overlap=cfg.overlap)
        pr = (prob > cfg.threshold).astype(np.uint8)

        stem = Path(path).stem

        # Save predicted mask
        cv2.imwrite(str(out_dir / "pred_masks" / f"{stem}_pred.png"), (pr * 255).astype(np.uint8))

        # Save + show 3-panel for ALL
        title = f"{spec['name']} | {Path(path).name}"
        three_panel_figure(cfg, img, gt, pr, title, out_dir / "panel_all" / f"{stem}_img_gt_pred.png")

        # Seg metrics
        dice = dice_score_bin(pr, gt)
        iou = iou_score_bin(pr, gt)

        # Descriptors
        d_gt = compute_descriptors(cfg, gt)
        d_pr = compute_descriptors(cfg, pr)

        row = {"image": path, "dice": dice, "iou": iou}
        for k in metric_list:
            row[f"gt_{k}"] = d_gt[k]
            row[f"pr_{k}"] = d_pr[k]
        rows.append(row)

    df_res = pd.DataFrame(rows)
    df_res.to_csv(out_dir / "test_results.csv", index=False)

    # Descriptor plots (scatter + BA) for ALL descriptors with y=x, y=ax+b, R²
    summary = {
        "name": spec["name"],
        "arch": spec["arch"],
        "encoder": spec["encoder"],
        "best_val_dice": float(best_va_dice),
        "best_epoch": int(best_epoch),
        "test_dice_mean": float(np.nanmean(df_res["dice"].values)),
        "test_iou_mean": float(np.nanmean(df_res["iou"].values)),
    }

    for m in metric_list:
        gt_arr = df_res[f"gt_{m}"].values
        pr_arr = df_res[f"pr_{m}"].values

        stats = scatter_plot_with_fit(
            cfg, gt_arr, pr_arr,
            title=f"{spec['name']} | {m}: Pred vs GT",
            save_path=out_dir / "figs_test" / f"scatter_{m}.png",
        )
        ba = bland_altman_plot(
            cfg, gt_arr, pr_arr,
            title=f"{spec['name']} | {m}: Bland–Altman",
            save_path=out_dir / "figs_test" / f"ba_{m}.png",
        )

        if stats is not None:
            summary[f"{m}_slope_a"] = stats["a"]
            summary[f"{m}_intercept_b"] = stats["b"]
            summary[f"{m}_r2_pred"] = stats["r2_pred"]
            summary[f"{m}_r2_fit"] = stats["r2_fit"]
            summary[f"{m}_r2_pear"] = stats["r2_pear"]
        else:
            summary[f"{m}_slope_a"] = np.nan
            summary[f"{m}_intercept_b"] = np.nan
            summary[f"{m}_r2_pred"] = np.nan
            summary[f"{m}_r2_fit"] = np.nan
            summary[f"{m}_r2_pear"] = np.nan

        if ba is not None:
            summary[f"{m}_bias"] = ba["bias"]
            summary[f"{m}_loa_low"] = ba["loa_low"]
            summary[f"{m}_loa_high"] = ba["loa_high"]
        else:
            summary[f"{m}_bias"] = np.nan
            summary[f"{m}_loa_low"] = np.nan
            summary[f"{m}_loa_high"] = np.nan

    with open(out_dir / "test_summary.json", "w") as f:
        json.dump(summary, f, indent=2)

    print("Saved run folder:", out_dir)
    return summary


