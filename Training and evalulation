def _list_valid_files(d: PathLike, exts=IMG_EXTS) -> List[Path]:
    d = Path(d)
    files = []
    for p in d.iterdir():
        if not p.is_file():
            continue
        if p.name.startswith("."):
            continue
        if p.suffix.lower() not in exts:
            continue
        files.append(p)
    return sorted(files)

def build_pairs_exact(img_dir: str, mask_dir: str, mask_suffix: str,
                      prefer_exts=(".png", ".tif", ".tiff", ".jpg", ".jpeg")) -> Tuple[List[Tuple[str,str]], pd.DataFrame]:
    img_files = _list_valid_files(img_dir)
    mask_files = _list_valid_files(mask_dir)

    masks_by_stem: Dict[str, List[Path]] = {}
    for m in mask_files:
        masks_by_stem.setdefault(m.stem, []).append(m)

    rows = []
    pairs: List[Tuple[str,str]] = []

    for im in img_files:
        stem = im.stem
        expected = f"{stem}{mask_suffix}"
        candidates = masks_by_stem.get(expected, [])

        status = "OK"
        chosen = None

        if len(candidates) == 0:
            status = "MISSING_MASK"
        else:
            cand_sorted = sorted(
                candidates,
                key=lambda p: (prefer_exts.index(p.suffix.lower()) if p.suffix.lower() in prefer_exts else 999, str(p))
            )
            chosen = cand_sorted[0]
            if len(candidates) > 1:
                status = f"DUPLICATE_MASKS({len(candidates)})"

        rows.append({
            "image": str(im),
            "image_stem": stem,
            "expected_mask_stem": expected,
            "mask_chosen": str(chosen) if chosen is not None else "",
            "n_mask_candidates_exact": len(candidates),
            "status": status
        })

        if chosen is not None:
            pairs.append((str(im), str(chosen)))

    report = pd.DataFrame(rows)
    return pairs, report

def split_train_val(pairs: List[Tuple[str,str]], val_fraction: float, seed: int):
    pairs = pairs.copy()
    rnd = random.Random(seed)
    rnd.shuffle(pairs)
    n_val = max(1, int(len(pairs) * val_fraction))
    return pairs[n_val:], pairs[:n_val]


