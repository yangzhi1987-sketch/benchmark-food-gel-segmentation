# MAIN
# =========================
def main():
    cfg = CFG()
    seed_everything(cfg.seed)
    ensure_dir(cfg.output_root)

    # Pairing reports
    train_pairs, train_report = build_pairs_exact(cfg.train_images_dir, cfg.train_masks_dir, cfg.train_mask_suffix)
    test_pairs,  test_report  = build_pairs_exact(cfg.test_images_dir,  cfg.test_masks_dir,  cfg.test_mask_suffix)

    pairing_dir = Path(cfg.output_root) / "_pairing_reports"
    ensure_dir(pairing_dir)
    train_report.to_csv(pairing_dir / "pairing_train_report.csv", index=False)
    test_report.to_csv(pairing_dir / "pairing_test_report.csv", index=False)

    print("Pairing summary (train):")
    print(train_report["status"].value_counts())
    print("Pairing summary (test):")
    print(test_report["status"].value_counts())

    # Keep only OK pairs
    train_pairs_ok = [(r["image"], r["mask_chosen"]) for _, r in train_report.iterrows() if r["status"].startswith("OK")]
    test_pairs_ok  = [(r["image"], r["mask_chosen"]) for _, r in test_report.iterrows()  if r["status"].startswith("OK")]

    # Split train/val
    train_pairs_ok, val_pairs_ok = split_train_val(train_pairs_ok, cfg.val_fraction, cfg.seed)
    print(f"Train pairs: {len(train_pairs_ok)} | Val pairs: {len(val_pairs_ok)} | Test pairs: {len(test_pairs_ok)}")

    # Augmentations
    aug_train = get_train_aug()
    aug_val = get_val_aug()

    # Model suite
    suite = get_model_suite_mps()

    all_summaries = []
    for spec in suite:
        try:
            print(f"\n=== Running {spec['name']} ({spec['arch']} + {spec['encoder']}) ===")
            summary = train_and_evaluate_one(cfg, spec, train_pairs_ok, val_pairs_ok, test_pairs_ok, aug_train, aug_val)
            all_summaries.append(summary)
            pd.DataFrame(all_summaries).to_csv(Path(cfg.output_root) / "leaderboard_running.csv", index=False)
        except Exception as e:
            print(f"[SKIP/ERROR] {spec['name']} -> {repr(e)}")
            continue

    leader = pd.DataFrame(all_summaries)
    leader.to_csv(Path(cfg.output_root) / "leaderboard_final.csv", index=False)
    print("\nDone. Leaderboard saved to:", Path(cfg.output_root) / "leaderboard_final.csv")

    # Cross-model summary plots
    summary_dir = Path(cfg.output_root) / "__SUMMARY__"
    plot_model_summary(cfg, leader, summary_dir)
    leader.to_csv(summary_dir / "leaderboard_final_copy.csv", index=False)
    print("Summary figures saved to:", summary_dir)


if __name__ == "__main__":
    main()

