# LOSS + SEG METRICS
# =========================
def dice_loss_with_logits(logits: torch.Tensor, targets: torch.Tensor, eps: float = 1e-6) -> torch.Tensor:
    probs = torch.sigmoid(logits)
    num = 2.0 * (probs * targets).sum(dim=(2, 3))
    den = (probs + targets).sum(dim=(2, 3)) + eps
    return 1.0 - (num / den).mean()

def dice_score_bin(pred: np.ndarray, gt: np.ndarray) -> float:
    pred = (pred > 0).astype(np.uint8)
    gt = (gt > 0).astype(np.uint8)
    inter = int((pred & gt).sum())
    den = int(pred.sum() + gt.sum()) + 1
    return float(2.0 * inter / den)

def iou_score_bin(pred: np.ndarray, gt: np.ndarray) -> float:
    pred = (pred > 0).astype(np.uint8)
    gt = (gt > 0).astype(np.uint8)
    inter = int((pred & gt).sum())
    union = int((pred | gt).sum()) + 1
    return float(inter / union)


# =========================
# SLIDING WINDOW INFERENCE
# =========================
@torch.no_grad()
def predict_full_prob(model: nn.Module, img: np.ndarray, device: torch.device,
                      patch: int, overlap: int) -> np.ndarray:
    model.eval()
    H, W = img.shape
    step = max(1, patch - overlap)

    prob = np.zeros((H, W), np.float32)
    cnt  = np.zeros((H, W), np.float32)

    for y in range(0, H, step):
        for x in range(0, W, step):
            y1 = min(y, max(0, H - patch)) if H >= patch else 0
            x1 = min(x, max(0, W - patch)) if W >= patch else 0

            crop = img[y1:y1+patch, x1:x1+patch]
            if crop.shape[0] != patch or crop.shape[1] != patch:
                crop = cv2.copyMakeBorder(
                    crop,
                    0, patch - crop.shape[0],
                    0, patch - crop.shape[1],
                    borderType=cv2.BORDER_REFLECT
                )

            ten = torch.from_numpy(crop).unsqueeze(0).unsqueeze(0).float().to(device)
            logits = model(ten)
            p = torch.sigmoid(logits).squeeze().detach().cpu().numpy()

            hh = min(patch, H - y1)
            ww = min(patch, W - x1)
            prob[y1:y1+hh, x1:x1+ww] += p[:hh, :ww]
            cnt[y1:y1+hh, x1:x1+ww] += 1.0

    return prob / np.maximum(cnt, 1e-6)


